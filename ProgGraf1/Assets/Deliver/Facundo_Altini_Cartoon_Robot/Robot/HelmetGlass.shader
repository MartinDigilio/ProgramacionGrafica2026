			o.Emission = color12.rgb;
			o.Smoothness = _Float0;
			o.Alpha = _Float1;
		}

		ENDCG
		CGPROGRAM
		#pragma surface surf Standard alpha:fade keepalpha fullforwardshadows exclude_path:deferred 

